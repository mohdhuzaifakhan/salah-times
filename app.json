{
  "expo": {
    "name": "Salah Times",
    "slug": "salah-times",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "salah-times",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAFBF6"
    },
    "android": {
      "package": "com.myapp.salahtimes",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png"
      }
    },
    "ios": {
      "bundleIdentifier": "com.myapp.salahtimes",
      "buildNumber": "1",
      "supportsTablet": true
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "cafc2b0c-71a4-4d2e-b51d-7fcd4cd29f3f"
      }
    }
  }
}
